# Integration test database (local MySQL on port 3306, no password — matches apps/backend/.env)
INTEGRATION_DATABASE_URL=mysql://root@127.0.0.1:3306/kuberone_integration_test

# Docker Compose alternative (port 3307, password integration)
# INTEGRATION_DATABASE_URL=mysql://root:integration@127.0.0.1:3307/kuberone_integration_test

# Use Testcontainers when Docker is available
# USE_TESTCONTAINERS=true
