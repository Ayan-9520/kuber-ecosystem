{
  "name": "kuberone",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne — AI-Powered Financial Services Ecosystem by Kuber Finserve",
  "author": "Kuber Finserve",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:backend": "turbo run dev --filter=@kuberone/backend",
    "dev:admin": "turbo run dev --filter=@kuberone/admin",
    "dev:mobile-customer": "turbo run dev --filter=@kuberone/mobile-customer",
    "dev:mobile-dsa": "turbo run dev --filter=@kuberone/mobile-dsa",
    "build": "turbo run build",
    "lint": "turbo run lint --concurrency=2",
    "lint:fix": "turbo run lint:fix --concurrency=2",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @kuberone/backend test:integration",
    "integration:up": "docker compose -f docker/docker-compose.integration.yml --env-file docker/.env.integration.example up -d",
    "integration:down": "docker compose -f docker/docker-compose.integration.yml down",
    "integration:prepare": "node -e \"console.log('Set INTEGRATION_DATABASE_URL=mysql://root@127.0.0.1:3306/kuberone_integration_test (or use integration:up with Docker)')\"",
    "cert:readiness": "node scripts/production-readiness-report.mjs",
    "cert:validation": "node scripts/audit-route-validation.mjs",
    "test:all": "pnpm test && pnpm test:integration",
    "test:coverage": "turbo run test:coverage",
    "test:mobile": "pnpm --filter @kuberone/mobile-customer test && pnpm --filter @kuberone/mobile-dsa test",
    "test:mobile:coverage": "pnpm --filter @kuberone/mobile-customer test:coverage && pnpm --filter @kuberone/mobile-dsa test:coverage",
    "test:detox": "pnpm --filter @kuberone/mobile-customer test:detox && pnpm --filter @kuberone/mobile-dsa test:detox",
    "test:e2e": "maestro test maestro/",
    "test:mobile:report": "node scripts/mobile-coverage-report.mjs",
    "test:mobile:gate": "node scripts/mobile-quality-gate.mjs",
    "security:test": "pnpm --filter @kuberone/security-testing build && pnpm --filter @kuberone/backend test:security && pnpm --filter @kuberone/admin exec vitest run tests/security && pnpm --filter @kuberone/mobile-customer exec jest tests/security --runInBand && pnpm --filter @kuberone/mobile-dsa exec jest tests/security --runInBand",
    "security:scan": "node scripts/security-scan.mjs",
    "security:owasp": "pnpm security:test",
    "security:report": "node scripts/security-coverage-report.mjs",
    "security:gate": "node scripts/security-quality-gate.mjs",
    "perf:test": "pnpm --filter @kuberone/performance-testing build && pnpm --filter @kuberone/backend test:performance && pnpm --filter @kuberone/admin exec vitest run tests/performance && pnpm --filter @kuberone/mobile-customer exec jest tests/performance --runInBand && pnpm --filter @kuberone/mobile-dsa exec jest tests/performance --runInBand",
    "perf:load": "node scripts/perf-run.mjs load",
    "perf:stress": "node scripts/perf-run.mjs stress",
    "perf:spike": "node scripts/perf-run.mjs spike",
    "perf:endurance": "node scripts/perf-run.mjs endurance",
    "perf:smoke": "node scripts/perf-run.mjs smoke",
    "perf:report": "node scripts/perf-coverage-report.mjs",
    "perf:optimize": "node scripts/perf-optimize.mjs",
    "perf:gate": "node scripts/perf-quality-gate.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm --filter @kuberone/database generate",
    "db:migrate": "pnpm --filter @kuberone/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @kuberone/database migrate:deploy",
    "db:seed": "pnpm --filter @kuberone/database seed",
    "db:seed:dev": "pnpm --filter @kuberone/database exec tsx prisma/seeds/dev.seed.ts",
    "db:seed:dev-accounts": "pnpm --filter @kuberone/database exec tsx prisma/seeds/dev-accounts-only.ts",
    "db:seed:integration": "pnpm --filter @kuberone/database exec tsx prisma/seeds/integration.seed.ts",
    "db:purge-demo": "node database/scripts/purge-demo-data.mjs",
    "db:cleanup": "node database/scripts/purge-demo-data.mjs && node database/scripts/cleanup-mysql.mjs",
    "db:status": "node database/scripts/db-status.mjs",
    "db:setup": "node database/scripts/setup-local.mjs",
    "db:docker": "docker compose -f docker/docker-compose.dev.yml up -d",
    "db:docker:down": "docker compose -f docker/docker-compose.dev.yml down",
    "db:studio": "pnpm --filter @kuberone/database studio",
    "audit:enterprise": "node scripts/enterprise-audit.mjs",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "openapi:validate": "node scripts/openapi-validate.mjs",
    "db:migration:gate": "node scripts/prisma-migration-gate.mjs",
    "coverage:gate": "node scripts/coverage-gate.mjs",
    "devops:record": "node scripts/ci-record-pipeline.mjs",
    "staging:validate": "node scripts/staging-deploy-validate.mjs",
    "staging:seed": "node scripts/staging-seed-masked.mjs",
    "production:gate": "node scripts/production-go-live-gate.mjs",
    "production:validate": "node scripts/production-deploy-validate.mjs",
    "android:gate": "node scripts/android-release-gate.mjs",
    "android:prebuild:customer": "pnpm --filter @kuberone/mobile-customer android:prebuild",
    "android:prebuild:dsa": "pnpm --filter @kuberone/mobile-dsa android:prebuild",
    "android:apk:customer": "pnpm --filter @kuberone/mobile-customer android:apk",
    "android:apk:dsa": "pnpm --filter @kuberone/mobile-dsa android:apk",
    "android:aab:customer": "pnpm --filter @kuberone/mobile-customer android:aab",
    "android:aab:dsa": "pnpm --filter @kuberone/mobile-dsa android:aab",
    "play-store:gate": "node scripts/play-store-release-gate.mjs",
    "play-store:report": "node scripts/play-store-readiness-report.mjs",
    "app-store:gate": "node scripts/app-store-release-gate.mjs",
    "app-store:report": "node scripts/app-store-readiness-report.mjs",
    "backend-deployment:gate": "node scripts/backend-deployment-gate.mjs",
    "backend-deployment:report": "node scripts/backend-deployment-readiness-report.mjs",
    "dr:gate": "node scripts/dr-gate.mjs",
    "dr:report": "node scripts/dr-readiness-report.mjs",
    "go-live:gate": "node scripts/go-live-gate.mjs",
    "go-live:report": "node scripts/go-live-readiness-report.mjs",
    "go-live:execution:gate": "node scripts/go-live-execution-gate.mjs",
    "go-live:execution:report": "node scripts/go-live-execution-report.mjs",
    "hypercare:gate": "node scripts/hypercare-gate.mjs",
    "hypercare:report": "node scripts/hypercare-report.mjs",
    "uat:gate": "node scripts/uat-signoff-gate.mjs",
    "uat:report": "node scripts/uat-signoff-report.mjs",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "artillery": "^2.0.32",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "joi": ">=17.13.4",
      "undici": ">=6.24.0",
      "@xmldom/xmldom": ">=0.8.13",
      "tar": ">=7.5.11",
      "postcss": ">=8.5.10"
    }
  }
}
