# Set false to test against real backend API
VITE_USE_MOCK=false
# Local dev: relative path (Vite proxies /api → localhost:4000)
VITE_API_BASE_URL=/api/v1
# Vercel + Cloudflare tunnel demo: set in Vercel env to your tunnel, e.g.
# VITE_API_BASE_URL=https://your-subdomain.trycloudflare.com/api/v1
# Production: point to your hosted API, e.g. VITE_API_BASE_URL=https://api.kuberone.com/api/v1
VITE_APP_ENV=development
