# Set false to test against real backend API
VITE_USE_MOCK=false
# MUST end with /api/v1 — tunnel root alone causes 404 "Route not found"
VITE_API_BASE_URL=/api/v1
# Vercel production example (suffix required):
# VITE_API_BASE_URL=https://your-subdomain.trycloudflare.com/api/v1
# VITE_API_BASE_URL=https://api.kuberone.com/api/v1
VITE_APP_ENV=development
