{
  "name": "@kuberone/admin",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne CRM Admin Panel",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@kuberone/shared-theme": "workspace:*",
    "@kuberone/shared-types": "workspace:*",
    "@kuberone/shared-utils": "workspace:*",
    "@kuberone/shared-validation": "workspace:*",
    "@reduxjs/toolkit": "^2.5.0",
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.7.9",
    "js-yaml": "^4.2.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.8.1",
    "redoc": "^2.5.3",
    "swagger-ui-react": "^5.32.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@kuberone/performance-testing": "workspace:*",
    "@kuberone/security-testing": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.6",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.6"
  }
}
