{
  "name": "@kuberone/mobile-customer",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne Customer Mobile App",
  "main": "index.ts",
  "scripts": {
    "dev": "node ../../scripts/expo-web-dev.mjs 8081",
    "start": "node ../../scripts/expo-web-dev.mjs 8081",
    "start:clear": "node ../../scripts/kill-dev-port.mjs 8081 && node ../../scripts/expo-web-dev.mjs 8081 --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "node ../../scripts/tsc.mjs --noEmit",
    "test": "node ../../node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node ../../node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node ../../node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:detox": "detox test -c ios.sim",
    "test:detox:android": "detox test -c android.emu",
    "test:detox:build": "detox build -c ios.sim",
    "clean": "rimraf .expo dist coverage",
    "android:prebuild": "expo prebuild --platform android --clean",
    "android:apk": "expo run:android --variant release",
    "android:aab": "cd android && ./gradlew bundleRelease",
    "android:debug": "expo run:android --variant debug"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.4",
    "@kuberone/shared-theme": "workspace:*",
    "@kuberone/shared-types": "workspace:*",
    "@kuberone/shared-utils": "workspace:*",
    "@kuberone/shared-validation": "workspace:*",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@reduxjs/toolkit": "^2.5.0",
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.7.9",
    "expo": "~52.0.23",
    "expo-build-properties": "~0.13.2",
    "expo-constants": "~17.0.8",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-linear-gradient": "~14.0.2",
    "expo-secure-store": "~14.0.1",
    "expo-speech": "~13.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "react-redux": "^9.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-flow-strip-types": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "babel-jest": "^29.7.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@babel/preset-react": "^7.26.0",
    "jest-environment-jsdom": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "@kuberone/mobile-testing": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
