# Local web dev: pnpm dev:mobile-customer → http://localhost:8081 (F12 for mobile view)
# Backend must be running: pnpm dev:backend (port 4000)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# When testing from Vercel, phone browser, or Cloudflare tunnel — copy to .env.local:
# EXPO_PUBLIC_API_BASE_URL=https://your-tunnel.trycloudflare.com/api/v1
# Then restart: pnpm dev:mobile-customer

# Production builds use .env.production (api.kuberone.com) unless overridden here.

EXPO_PUBLIC_APP_ENV=development

# Per-environment files: .env.qa, .env.staging, .env.production
EXPO_PUBLIC_CRASH_REPORTING=false
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_FCM_ENABLED=true
EXPO_PUBLIC_OPENAI_ENABLED=true

# Firebase Crashlytics — copy google-services.json.example → google-services.json
# GOOGLE_SERVICES_JSON=./google-services.json
