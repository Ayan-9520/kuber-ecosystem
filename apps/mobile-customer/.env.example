# Local web + iOS simulator (same machine as backend):
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Physical phone (same WiFi) — replace with your PC IPv4 (run: ipconfig)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.2:4000/api/v1

# Android Emulator:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000/api/v1

EXPO_PUBLIC_APP_ENV=development

# Per-environment files: .env.qa, .env.staging, .env.production
EXPO_PUBLIC_CRASH_REPORTING=false
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_FCM_ENABLED=true
EXPO_PUBLIC_OPENAI_ENABLED=true

# Firebase Crashlytics — copy google-services.json.example → google-services.json
# GOOGLE_SERVICES_JSON=./google-services.json
