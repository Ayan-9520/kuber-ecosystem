NODE_ENV=development
APP_ENV=development

API_PORT=4000
API_BASE_URL=http://localhost:4000
API_VERSION=v1

DATABASE_URL="mysql://root@127.0.0.1:3306/kuberone_dev"

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kuberone-dev-documents

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:8082

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7
