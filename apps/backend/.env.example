NODE_ENV=development
APP_ENV=development

API_PORT=4000
API_BASE_URL=http://localhost:4000
API_VERSION=v1

DATABASE_URL="mysql://root@127.0.0.1:3306/kuberone_dev"
DATABASE_CONNECTION_LIMIT=10

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
DATA_ENCRYPTION_KEY=change-me-field-encryption-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kuberone-dev-documents

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# When OPENAI_API_KEY is set, use OpenAI embeddings for RAG (production default)
EMBEDDING_PROVIDER=openai

# Dev also auto-allows any http://localhost:<port> when APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:8082,http://localhost:8083

# Staged production rollout — start with MySQL + OpenAI only; add providers later
# DEPLOYMENT_ROLLOUT_PHASE=staged   (default) | full
DEPLOYMENT_ROLLOUT_PHASE=staged

# Per-channel toggles (false = Disabled; true without credentials = Not Configured)
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
NOTIFICATION_WHATSAPP_ENABLED=true
NOTIFICATION_PUSH_ENABLED=true

# Optional — enables distributed rate limiting and analytics cache (required for full public launch)
REDIS_URL=redis://localhost:6379

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Scalability: disable on API-only PM2 instances; enable on dedicated worker process
API_WORKERS_ENABLED=true
LEAD_EXPORT_MAX_ROWS=5000

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7

# Logging & Observability (Pino + OpenTelemetry)
LOG_LEVEL=info
LOG_SAMPLE_RATE=1
TRACE_SAMPLE_RATE=1
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Backup & Recovery
AWS_S3_BACKUP_BUCKET=kuberone-backups-dev
BACKUP_WORKER_ENABLED=true
BACKUP_WORKER_INTERVAL_MS=3600000
ERROR_GATE_MAX_CRITICAL=5

# DevOps / CI/CD
DEVOPS_WEBHOOK_SECRET=change-me-devops-webhook-secret-min-16
STAGING_WEBHOOK_SECRET=change-me-staging-webhook-secret-min-16
PRODUCTION_WEBHOOK_SECRET=change-me-production-webhook-secret-min-16
MOBILE_WEBHOOK_SECRET=change-me-mobile-webhook-secret-min-16
PLAY_STORE_WEBHOOK_SECRET=change-me-play-store-webhook-secret-min-16
APP_STORE_WEBHOOK_SECRET=change-me-app-store-webhook-secret-min-16
BACKEND_DEPLOYMENT_WEBHOOK_SECRET=change-me-backend-deployment-webhook-secret-min-16
DR_WEBHOOK_SECRET=change-me-dr-webhook-secret-min-16
