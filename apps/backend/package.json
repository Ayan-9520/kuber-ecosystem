{
  "name": "@kuberone/backend",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne Express API Server",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "node ../../node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "node ../../scripts/tsc.mjs -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "node ../../scripts/tsc.mjs -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.unit.config.ts --runInBand",
    "test:integration": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.integration.config.ts --runInBand",
    "test:all": "pnpm test && pnpm test:integration",
    "test:watch": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.unit.config.ts --watch",
    "test:security": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.security.config.ts --runInBand",
    "test:performance": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.performance.config.ts --runInBand --forceExit",
    "test:coverage": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.unit.config.ts --coverage --runInBand",
    "test:coverage:integration": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.integration.config.ts --coverage --runInBand",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.709.0",
    "@aws-sdk/client-ses": "^3.1063.0",
    "@aws-sdk/client-sns": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.709.0",
    "@kuberone/database": "workspace:*",
    "@kuberone/shared-config": "workspace:*",
    "@kuberone/shared-types": "workspace:*",
    "@kuberone/shared-utils": "workspace:*",
    "@kuberone/shared-validation": "workspace:*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@kuberone/performance-testing": "workspace:*",
    "@kuberone/security-testing": "workspace:*",
    "@kuberone/test-utils": "workspace:*",
    "@testcontainers/mysql": "^10.28.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.10",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "testcontainers": "^10.28.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
