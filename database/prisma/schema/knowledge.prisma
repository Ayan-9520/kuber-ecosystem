// ── AI Knowledge Base Management Domain ──

enum KnowledgeContentType {
  ARTICLE
  POLICY
  FAQ
  SOP
  TRAINING_MATERIAL
  SCRIPT
  VIDEO_METADATA
  DOCUMENT_METADATA
}

enum KnowledgeLifecycleStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum KnowledgeApprovalAction {
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
  ROLLED_BACK
}

enum KnowledgeAuditAction {
  CREATED
  UPDATED
  DELETED
  PUBLISHED
  ARCHIVED
  VERSION_CREATED
  APPROVAL_SUBMITTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  FEEDBACK_ADDED
  VIEWED
  SEARCHED
}

model KnowledgeCategory {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(150)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Char(36)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   KnowledgeCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children KnowledgeCategory[] @relation("CategoryHierarchy")
  articles KnowledgeArticle[]

  @@index([parentId, isActive])
  @@map("knowledge_categories")
}

model KnowledgeArticle {
  id              String                 @id @default(uuid()) @db.Char(36)
  slug            String                 @unique @db.VarChar(200)
  title           String                 @db.VarChar(300)
  summary         String?                @db.Text
  content         String                 @db.LongText
  contentType     KnowledgeContentType   @map("content_type")
  categoryId      String                 @map("category_id") @db.Char(36)
  status          KnowledgeLifecycleStatus @default(DRAFT)
  currentVersion  Int                    @default(1) @map("current_version")
  authorId        String?                @map("author_id") @db.Char(36)
  reviewerId      String?                @map("reviewer_id") @db.Char(36)
  approverId      String?                @map("approver_id") @db.Char(36)
  publisherId     String?                @map("publisher_id") @db.Char(36)
  publishedAt     DateTime?              @map("published_at")
  archivedAt      DateTime?              @map("archived_at")
  viewCount       Int                    @default(0) @map("view_count")
  searchKeywords  String?                @map("search_keywords") @db.Text
  semanticReady   Boolean                @default(true) @map("semantic_ready")
  department      String?                @db.VarChar(100)
  productCode     String?                @map("product_code") @db.VarChar(50)
  lenderCode      String?                @map("lender_code") @db.VarChar(50)
  riskCategory    String?                @map("risk_category") @db.VarChar(50)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  category    KnowledgeCategory      @relation(fields: [categoryId], references: [id])
  versions    KnowledgeVersion[]
  articleTags KnowledgeArticleTag[]
  attachments KnowledgeAttachment[]
  approvals   KnowledgeApproval[]
  reviews     KnowledgeReview[]
  feedback    KnowledgeFeedback[]
  views       KnowledgeView[]

  @@index([categoryId, status])
  @@index([contentType, status])
  @@index([status, publishedAt])
  @@index([productCode])
  @@index([lenderCode])
  @@fulltext([title, summary, content, searchKeywords])
  @@map("knowledge_articles")
}

model KnowledgeVersion {
  id          String   @id @default(uuid()) @db.Char(36)
  articleId   String   @map("article_id") @db.Char(36)
  version     Int
  title       String   @db.VarChar(300)
  summary     String?  @db.Text
  content     String   @db.LongText
  changeNotes String?  @map("change_notes") @db.Text
  createdById String?  @map("created_by_id") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, version])
  @@index([articleId, createdAt])
  @@map("knowledge_versions")
}

model KnowledgeTag {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  tagGroup  String   @map("tag_group") @db.VarChar(50)
  color     String?  @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  articleTags KnowledgeArticleTag[]

  @@index([tagGroup, isActive])
  @@map("knowledge_tags")
}

model KnowledgeArticleTag {
  id        String   @id @default(uuid()) @db.Char(36)
  articleId String   @map("article_id") @db.Char(36)
  tagId     String   @map("tag_id") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     KnowledgeTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@map("knowledge_article_tags")
}

model KnowledgeAttachment {
  id          String   @id @default(uuid()) @db.Char(36)
  articleId   String   @map("article_id") @db.Char(36)
  fileName    String   @map("file_name") @db.VarChar(255)
  fileType    String   @map("file_type") @db.VarChar(50)
  fileSize    Int?     @map("file_size")
  storageUrl  String?  @map("storage_url") @db.Text
  metadata    Json?
  uploadedById String? @map("uploaded_by_id") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("knowledge_attachments")
}

model KnowledgeApproval {
  id          String                  @id @default(uuid()) @db.Char(36)
  articleId   String                  @map("article_id") @db.Char(36)
  version     Int
  action      KnowledgeApprovalAction
  actorId     String                  @map("actor_id") @db.Char(36)
  actorRole   String                  @map("actor_role") @db.VarChar(50)
  comments    String?                 @db.Text
  createdAt   DateTime                @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@index([action])
  @@map("knowledge_approvals")
}

model KnowledgeReview {
  id          String   @id @default(uuid()) @db.Char(36)
  articleId   String   @map("article_id") @db.Char(36)
  reviewerId  String   @map("reviewer_id") @db.Char(36)
  rating      Int?
  comments    String?  @db.Text
  status      String   @default("PENDING") @db.VarChar(20)
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, status])
  @@index([reviewerId])
  @@map("knowledge_reviews")
}

model KnowledgeFeedback {
  id        String   @id @default(uuid()) @db.Char(36)
  articleId String   @map("article_id") @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  rating    Int
  comment   String?  @db.Text
  helpful   Boolean?
  createdAt DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@map("knowledge_feedback")
}

model KnowledgeView {
  id        String   @id @default(uuid()) @db.Char(36)
  articleId String   @map("article_id") @db.Char(36)
  userId    String?  @map("user_id") @db.Char(36)
  source    String?  @db.VarChar(50)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt])
  @@index([userId])
  @@map("knowledge_views")
}

model KnowledgeAudit {
  id         String               @id @default(uuid()) @db.Char(36)
  userId     String               @map("user_id") @db.Char(36)
  action     KnowledgeAuditAction
  entityType String               @map("entity_type") @db.VarChar(50)
  entityId   String?              @map("entity_id") @db.Char(36)
  oldValues  Json?                @map("old_values")
  newValues  Json?                @map("new_values")
  ipAddress  String?              @map("ip_address") @db.VarChar(45)
  userAgent  String?              @map("user_agent") @db.Text
  requestId  String?              @map("request_id") @db.VarChar(64)
  createdAt  DateTime             @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("knowledge_audits")
}

model KnowledgeSearchHistory {
  id          String   @id @default(uuid()) @db.Char(36)
  userId      String?  @map("user_id") @db.Char(36)
  query       String   @db.VarChar(500)
  searchType  String   @map("search_type") @db.VarChar(30)
  filters     Json?
  resultCount Int      @map("result_count")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([query])
  @@map("knowledge_search_history")
}
