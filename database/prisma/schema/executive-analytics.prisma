// ── KuberOne Executive Analytics Module ──

enum ExecutiveRoleType {
  SALES_EXECUTIVE
  RELATIONSHIP_MANAGER
  CREDIT_EXECUTIVE
  OPERATIONS_EXECUTIVE
}

enum ExecutivePeriodType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model ExecutiveMetric {
  id            String              @id @default(uuid()) @db.Char(36)
  employeeId    String              @map("employee_id") @db.Char(36)
  executiveRole ExecutiveRoleType   @map("executive_role")
  metricCode    String              @map("metric_code") @db.VarChar(80)
  metricName    String              @map("metric_name") @db.VarChar(150)
  periodType    ExecutivePeriodType @map("period_type")
  periodStart   DateTime            @map("period_start") @db.Date
  periodEnd     DateTime            @map("period_end") @db.Date
  branchId      String?             @map("branch_id") @db.Char(36)
  regionId      String?             @map("region_id") @db.Char(36)
  productId     String?             @map("product_id") @db.Char(36)
  value         Decimal             @db.Decimal(18, 4)
  targetValue   Decimal?            @map("target_value") @db.Decimal(18, 4)
  unit          String?             @db.VarChar(30)
  dimensions    Json?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, periodType, periodStart])
  @@index([executiveRole, periodType, periodStart])
  @@index([metricCode, periodStart])
  @@map("executive_metrics")
}

model ExecutiveTarget {
  id            String              @id @default(uuid()) @db.Char(36)
  employeeId    String              @map("employee_id") @db.Char(36)
  executiveRole ExecutiveRoleType   @map("executive_role")
  metricCode    String              @map("metric_code") @db.VarChar(80)
  metricName    String              @map("metric_name") @db.VarChar(150)
  targetValue   Decimal             @map("target_value") @db.Decimal(18, 4)
  periodType    ExecutivePeriodType @map("period_type")
  periodStart   DateTime            @map("period_start") @db.Date
  periodEnd     DateTime            @map("period_end") @db.Date
  branchId      String?             @map("branch_id") @db.Char(36)
  regionId      String?             @map("region_id") @db.Char(36)
  productId     String?             @map("product_id") @db.Char(36)
  assignedById  String?             @map("assigned_by_id") @db.Char(36)
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedBy User?    @relation("ExecutiveTargetAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([employeeId, periodType, isActive])
  @@index([executiveRole, periodType, periodStart])
  @@map("executive_targets")
}

model ExecutivePerformance {
  id                String              @id @default(uuid()) @db.Char(36)
  employeeId        String              @map("employee_id") @db.Char(36)
  executiveRole     ExecutiveRoleType   @map("executive_role")
  periodType        ExecutivePeriodType @map("period_type")
  periodStart       DateTime            @map("period_start") @db.Date
  periodEnd         DateTime            @map("period_end") @db.Date
  performanceScore  Decimal             @map("performance_score") @db.Decimal(5, 2)
  productivityScore Decimal             @map("productivity_score") @db.Decimal(5, 2)
  qualityScore      Decimal             @map("quality_score") @db.Decimal(5, 2)
  complianceScore   Decimal             @map("compliance_score") @db.Decimal(5, 2)
  overallRating     Decimal             @map("overall_rating") @db.Decimal(5, 2)
  branchId          String?             @map("branch_id") @db.Char(36)
  regionId          String?             @map("region_id") @db.Char(36)
  breakdown         Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, periodType, periodStart])
  @@index([executiveRole, overallRating])
  @@map("executive_performances")
}

model ExecutiveLeaderboard {
  id            String              @id @default(uuid()) @db.Char(36)
  executiveRole ExecutiveRoleType   @map("executive_role")
  periodType    ExecutivePeriodType @map("period_type")
  periodStart   DateTime            @map("period_start") @db.Date
  periodEnd     DateTime            @map("period_end") @db.Date
  employeeId    String              @map("employee_id") @db.Char(36)
  rank          Int
  score         Decimal             @db.Decimal(8, 2)
  metrics       Json?
  branchId      String?             @map("branch_id") @db.Char(36)
  regionId      String?             @map("region_id") @db.Char(36)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([executiveRole, periodType, periodStart, rank], map: "exec_leaderboards_role_period_rank_idx")
  @@index([employeeId, periodType])
  @@map("executive_leaderboards")
}

model ExecutiveForecast {
  id              String              @id @default(uuid()) @db.Char(36)
  employeeId      String              @map("employee_id") @db.Char(36)
  executiveRole   ExecutiveRoleType   @map("executive_role")
  metricCode      String              @map("metric_code") @db.VarChar(80)
  periodType      ExecutivePeriodType @map("period_type")
  forecastDate    DateTime            @map("forecast_date") @db.Date
  predictedValue  Decimal             @map("predicted_value") @db.Decimal(18, 4)
  confidence      Decimal?            @db.Decimal(5, 2)
  modelVersion    String?             @map("model_version") @db.VarChar(30)
  branchId        String?             @map("branch_id") @db.Char(36)
  regionId        String?             @map("region_id") @db.Char(36)
  productId       String?             @map("product_id") @db.Char(36)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, metricCode, forecastDate])
  @@index([executiveRole, periodType])
  @@map("executive_forecasts")
}

model ExecutiveAnalyticsSnapshot {
  id            String               @id @default(uuid()) @db.Char(36)
  employeeId    String?              @map("employee_id") @db.Char(36)
  executiveRole ExecutiveRoleType?   @map("executive_role")
  snapshotDate  DateTime             @map("snapshot_date") @db.Date
  periodType    ExecutivePeriodType  @map("period_type")
  branchId      String?              @map("branch_id") @db.Char(36)
  regionId      String?              @map("region_id") @db.Char(36)
  payload       Json
  createdAt     DateTime             @default(now()) @map("created_at")

  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([snapshotDate, executiveRole])
  @@index([employeeId, snapshotDate])
  @@map("executive_analytics_snapshots")
}

model ExecutiveAnalyticsAudit {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @map("user_id") @db.Char(36)
  action     String   @db.VarChar(80)
  resource   String   @db.VarChar(80)
  resourceId String?  @map("resource_id") @db.Char(36)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation("ExecutiveAnalyticsAuditUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("executive_analytics_audits")
}
