// ── KuberOne Branch Analytics Module ──

enum BranchPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BranchRankingType {
  BRANCH
  REGIONAL
  PRODUCT
  REVENUE
}

enum BranchMetricCategory {
  LEAD
  APPLICATION
  REVENUE
  PRODUCT
  EXECUTIVE
  PARTNER
  COMMISSION
  SUPPORT
  AI
  GROWTH
}

model BranchMetric {
  id           String               @id @default(uuid()) @db.Char(36)
  branchId     String               @map("branch_id") @db.Char(36)
  regionId     String               @map("region_id") @db.Char(36)
  metricCode   String               @map("metric_code") @db.VarChar(80)
  metricName   String               @map("metric_name") @db.VarChar(150)
  category     BranchMetricCategory
  periodType   BranchPeriodType     @map("period_type")
  periodStart  DateTime             @map("period_start") @db.Date
  periodEnd    DateTime             @map("period_end") @db.Date
  productId    String?              @map("product_id") @db.Char(36)
  partnerId    String?              @map("partner_id") @db.Char(36)
  lenderId     String?              @map("lender_id") @db.Char(36)
  employeeId   String?              @map("employee_id") @db.Char(36)
  value        Decimal              @db.Decimal(18, 4)
  targetValue  Decimal?             @map("target_value") @db.Decimal(18, 4)
  unit         String?              @db.VarChar(30)
  dimensions   Json?
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, periodType, periodStart])
  @@index([regionId, category, periodStart])
  @@index([metricCode, periodStart])
  @@map("branch_metrics")
}

model BranchTarget {
  id           String           @id @default(uuid()) @db.Char(36)
  branchId     String           @map("branch_id") @db.Char(36)
  regionId     String           @map("region_id") @db.Char(36)
  metricCode   String           @map("metric_code") @db.VarChar(80)
  metricName   String           @map("metric_name") @db.VarChar(150)
  category     BranchMetricCategory
  targetValue  Decimal          @map("target_value") @db.Decimal(18, 4)
  periodType   BranchPeriodType @map("period_type")
  periodStart  DateTime         @map("period_start") @db.Date
  periodEnd    DateTime         @map("period_end") @db.Date
  productId    String?          @map("product_id") @db.Char(36)
  assignedById String?          @map("assigned_by_id") @db.Char(36)
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedBy User?  @relation("BranchTargetAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([branchId, periodType, isActive])
  @@index([regionId, category])
  @@map("branch_targets")
}

model BranchPerformance {
  id               String           @id @default(uuid()) @db.Char(36)
  branchId         String           @map("branch_id") @db.Char(36)
  regionId         String           @map("region_id") @db.Char(36)
  periodType       BranchPeriodType @map("period_type")
  periodStart      DateTime         @map("period_start") @db.Date
  periodEnd        DateTime         @map("period_end") @db.Date
  growthScore      Decimal          @map("growth_score") @db.Decimal(5, 2)
  revenueScore     Decimal          @map("revenue_score") @db.Decimal(5, 2)
  operationsScore  Decimal          @map("operations_score") @db.Decimal(5, 2)
  complianceScore  Decimal          @map("compliance_score") @db.Decimal(5, 2)
  customerScore    Decimal          @map("customer_score") @db.Decimal(5, 2)
  overallScore     Decimal          @map("overall_score") @db.Decimal(5, 2)
  breakdown        Json?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, periodType, periodStart])
  @@index([regionId, overallScore])
  @@map("branch_performances")
}

model BranchForecast {
  id             String           @id @default(uuid()) @db.Char(36)
  branchId       String           @map("branch_id") @db.Char(36)
  regionId       String           @map("region_id") @db.Char(36)
  metricCode     String           @map("metric_code") @db.VarChar(80)
  periodType     BranchPeriodType @map("period_type")
  forecastDate   DateTime         @map("forecast_date") @db.Date
  predictedValue Decimal          @map("predicted_value") @db.Decimal(18, 4)
  confidence     Decimal?         @db.Decimal(5, 2)
  modelVersion   String?          @map("model_version") @db.VarChar(30)
  productId      String?          @map("product_id") @db.Char(36)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([branchId, metricCode, forecastDate])
  @@map("branch_forecasts")
}

model BranchRanking {
  id           String            @id @default(uuid()) @db.Char(36)
  rankingType  BranchRankingType @map("ranking_type")
  periodType   BranchPeriodType  @map("period_type")
  periodStart  DateTime          @map("period_start") @db.Date
  periodEnd    DateTime          @map("period_end") @db.Date
  branchId     String?           @map("branch_id") @db.Char(36)
  regionId     String?           @map("region_id") @db.Char(36)
  productId    String?           @map("product_id") @db.Char(36)
  rank         Int
  score        Decimal           @db.Decimal(8, 2)
  metrics      Json?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([rankingType, periodType, periodStart, rank])
  @@index([branchId, periodType])
  @@map("branch_rankings")
}

model BranchAnalyticsSnapshot {
  id           String           @id @default(uuid()) @db.Char(36)
  branchId     String?          @map("branch_id") @db.Char(36)
  regionId     String?          @map("region_id") @db.Char(36)
  snapshotDate DateTime         @map("snapshot_date") @db.Date
  periodType   BranchPeriodType @map("period_type")
  payload      Json
  createdAt    DateTime         @default(now()) @map("created_at")

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([snapshotDate, branchId])
  @@index([regionId, snapshotDate])
  @@map("branch_analytics_snapshots")
}

model BranchAnalyticsAudit {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @map("user_id") @db.Char(36)
  action     String   @db.VarChar(80)
  resource   String   @db.VarChar(80)
  resourceId String?  @map("resource_id") @db.Char(36)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation("BranchAnalyticsAuditUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("branch_analytics_audits")
}
