  automationExecutions         AutomationExecution[]     @relation("AutomationExecutionUser")
  automationTemplatesCreated   AutomationTemplate[]      @relation("AutomationTemplateCreatedBy")
  automationAudits             AutomationAudit[]         @relation("AutomationAuditActor")
  contentTemplatesCreated      ContentTemplate[]         @relation("ContentTemplateCreatedBy")
  contentTemplatesUpdated      ContentTemplate[]         @relation("ContentTemplateUpdatedBy")
  contentRequests              ContentGenerationRequest[] @relation("ContentRequestRequestedBy")
  contentVersionsCreated       ContentVersion[]          @relation("ContentVersionCreatedBy")
  contentApprovalsReviewed     ContentApproval[]         @relation("ContentApprovalReviewer")
  contentFeedbackSubmitted     ContentFeedback[]         @relation("ContentFeedbackSubmittedBy")
  contentUsage                 ContentUsage[]            @relation("ContentUsageUsedBy")
  contentAudits                ContentAudit[]            @relation("ContentAuditActor")
  auditEvents                  AuditEvent[]              @relation("AuditEventUser")
  auditReportsGenerated        AuditReport[]             @relation("AuditReportGeneratedBy")
  auditExports                 AuditExport[]             @relation("AuditExportExportedBy")
  complianceRulesCreated       ComplianceRule[]          @relation("ComplianceRuleCreatedBy")
  complianceRulesUpdated       ComplianceRule[]          @relation("ComplianceRuleUpdatedBy")
  complianceViolations         ComplianceViolation[]     @relation("ComplianceViolationUser")
  complianceViolationsResolved ComplianceViolation[]     @relation("ComplianceViolationResolvedBy")
  complianceReportsGenerated   ComplianceReport[]        @relation("ComplianceReportGeneratedBy")
  riskRegisterOwned            RiskRegister[]            @relation("RiskRegisterOwner")
  riskRegisterCreated          RiskRegister[]            @relation("RiskRegisterCreatedBy")
  riskAssessments              RiskAssessment[]          @relation("RiskAssessmentAssessor")
  securityEvents               SecurityEvent[]           @relation("SecurityEventUser")
  securityAlertsAssigned       SecurityAlert[]           @relation("SecurityAlertAssignedTo")
  securityAlertsResolved       SecurityAlert[]           @relation("SecurityAlertResolvedBy")
  dataAccessLogs               DataAccessLog[]           @relation("DataAccessLogUser")
  governancePoliciesCreated    GovernancePolicy[]        @relation("GovernancePolicyCreatedBy")
  complianceAudits             ComplianceAudit[]         @relation("ComplianceAuditAuditor")
  uatPlansOwned                UatPlan[]                 @relation("UatPlanOwner")
  uatPlansCreated              UatPlan[]                 @relation("UatPlanCreatedBy")
  uatCyclesCreated             UatCycle[]                @relation("UatCycleCreatedBy")
  uatExecutions                UatExecution[]            @relation("UatExecutionExecutedBy")
  uatDefectsAssigned           UatDefect[]               @relation("UatDefectAssignedTo")
  uatDefectsReported           UatDefect[]               @relation("UatDefectReportedBy")
  uatDefectsResolved           UatDefect[]               @relation("UatDefectResolvedBy")
  uatSignoffs                  UatSignoff[]              @relation("UatSignoffSignedBy")
  uatApprovals                 UatApproval[]             @relation("UatApprovalApprovedBy")
  uatReviews                   UatReview[]               @relation("UatReviewReviewedBy")
  uatRisksOwned                UatRisk[]                 @relation("UatRiskOwner")
  uatRisksCreated              UatRisk[]                 @relation("UatRiskCreatedBy")
  uatComments                  UatComment[]              @relation("UatCommentAuthor")
  monitoringAlertsAcknowledged MonitoringAlert[]         @relation("MonitoringAlertAcknowledgedBy")
  monitoringAlertsResolved     MonitoringAlert[]         @relation("MonitoringAlertResolvedBy")
  observabilityLogs            ObservabilityLog[]        @relation("ObservabilityLogUser")
  observabilityTraces          ObservabilityTrace[]      @relation("ObservabilityTraceUser")
  observabilityErrors          ObservabilityError[]      @relation("ObservabilityErrorUser")
  observabilityEvents          ObservabilityEvent[]      @relation("ObservabilityEventUser")
  errorGroupsAssigned          ErrorGroup[]              @relation("ErrorGroupAssignedTo")
  errorEvents                  ErrorEvent[]              @relation("ErrorEventUser")
  errorAssignmentsReceived     ErrorAssignment[]         @relation("ErrorAssignmentAssignee")
  errorAssignmentsCreated      ErrorAssignment[]         @relation("ErrorAssignmentAssigner")
  errorResolutionsCreated      ErrorResolution[]         @relation("ErrorResolutionResolver")
  errorResolutionsVerified     ErrorResolution[]         @relation("ErrorResolutionVerifier")
  errorComments                ErrorComment[]            @relation("ErrorCommentAuthor")
  errorAlertsAcknowledged      ErrorAlert[]              @relation("ErrorAlertAcknowledgedBy")
  errorAlertsResolved          ErrorAlert[]              @relation("ErrorAlertResolvedBy")
  backupJobsCreated            BackupJob[]               @relation("BackupJobCreatedBy")
  restoreRequestsCreated       RestoreRequest[]          @relation("RestoreRequestRequestedBy")
  recoveryAuditsExecuted       RecoveryAudit[]           @relation("RecoveryAuditExecutedBy")
  deploymentsCreated           Deployment[]              @relation("DeploymentDeployedBy")
  releaseVersionsCreated       ReleaseVersion[]          @relation("ReleaseVersionCreatedBy")
  rollbacksExecuted            RollbackExecution[]       @relation("RollbackExecutedBy")
  deploymentAudits             DeploymentAudit[]         @relation("DeploymentAuditActor")
  stagingDeployments           EnvironmentDeployment[]   @relation("StagingDeploymentDeployedBy")
  releaseValidations           ReleaseValidation[]       @relation("ReleaseValidationValidatedBy")
  stagingAudits                StagingAudit[]            @relation("StagingAuditActor")
  productionDeployments        ProductionDeployment[]    @relation("ProductionDeploymentDeployedBy")
  releaseRecords               ReleaseRecord[]           @relation("ReleaseRecordReleasedBy")
  incidentsAssigned            IncidentRecord[]          @relation("IncidentRecordAssignedTo")
  productionAudits             ProductionAudit[]         @relation("ProductionAuditActor")
  backendDeployments           BackendDeployment[]       @relation("BackendDeploymentDeployedBy")
  deploymentVersionsReleased   DeploymentVersion[]       @relation("DeploymentVersionReleasedBy")
  backendDeploymentAudits      BackendDeploymentAudit[]  @relation("BackendDeploymentAuditActor")
  recoveryExecutions           RecoveryExecution[]       @relation("RecoveryExecutionExecutedBy")
  recoveryExecutionsApproved   RecoveryExecution[]       @relation("RecoveryExecutionApprovedBy")
  failoverExecutions           FailoverExecution[]       @relation("FailoverExecutionExecutedBy")
  drDrillsExecuted             DRDrill[]                 @relation("DRDrillExecutedBy")
  recoveryAuditLogs            RecoveryAuditLog[]        @relation("RecoveryAuditLogActor")
  goLiveChecklistsVerified     GoLiveChecklist[]         @relation("GoLiveChecklistVerifiedBy")
  launchExecutions             LaunchExecution[]         @relation("LaunchExecutionExecutedBy")
  goLiveApprovals              GoLiveApproval[]          @relation("GoLiveApprovalApprovedBy")
  launchAudits                 LaunchAudit[]             @relation("LaunchAuditActor")
  launchEvents                 LaunchEvent[]             @relation("LaunchEventActor")
  launchIncidentsAssigned      LaunchIncident[]          @relation("LaunchIncidentAssignedTo")
  warRoomSessionsCommanded     WarRoomSession[]          @relation("WarRoomCommander")
  hypercareIssuesAssigned      HypercareIssue[]          @relation("HypercareIssueAssignedTo")
  hypercareIncidentsAssigned   HypercareIncident[]       @relation("HypercareIncidentAssignedTo")
  hypercareRcasAuthored        HypercareRCA[]            @relation("HypercareRCAAuthoredBy")

  @@map("users")
  @@index([userType, status])
}

model Role {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(150)
  module      String   @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
  @@index([module])
}

model RolePermission {
  roleId       String @map("role_id") @db.Char(36)
  permissionId String @map("permission_id") @db.Char(36)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  roleId    String   @map("role_id") @db.Char(36)
  branchId  String?  @map("branch_id") @db.Char(36)
  regionId  String?  @map("region_id") @db.Char(36)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@map("user_roles")
}

model Session {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @map("user_id") @db.Char(36)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.Text
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]

  @@map("sessions")
  @@index([userId, expiresAt])
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @map("user_id") @db.Char(36)
  sessionId  String    @map("session_id") @db.Char(36)
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId, expiresAt])
  @@index([tokenHash])
}

model OtpVerification {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String?   @map("user_id") @db.Char(36)
  phone      String    @db.VarChar(15)
  otpHash    String    @map("otp_hash") @db.VarChar(255)
  purpose    String    @db.VarChar(30)
  attempts   Int       @default(0)
  verifiedAt DateTime? @map("verified_at")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("otp_verifications")
  @@index([phone, purpose, expiresAt])
}

model Device {
  id           String   @id @default(uuid()) @db.Char(36)
  userId       String   @map("user_id") @db.Char(36)
  deviceId     String   @map("device_id") @db.VarChar(100)
  platform     String   @db.VarChar(20)
  fcmToken     String?  @map("fcm_token") @db.VarChar(500)
  appVersion   String?  @map("app_version") @db.VarChar(20)
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushNotifications PushNotification[]

  @@unique([userId, deviceId])
  @@map("devices")
}

model LoginHistory {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String   @map("user_id") @db.Char(36)
  sessionId  String?  @map("session_id") @db.Char(36)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  success    Boolean  @default(true)
  failReason String?  @map("fail_reason") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("login_history")
  @@index([userId, createdAt])
}
