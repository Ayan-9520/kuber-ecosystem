  commissionRulesDeleted     CommissionRule[]     @relation("CommissionRuleDeletedBy")
  commissionLedgerCreated    CommissionLedger[]   @relation("CommissionLedgerCreatedBy")
  commissionLedgerUpdated    CommissionLedger[]   @relation("CommissionLedgerUpdatedBy")
  commissionLedgerDeleted    CommissionLedger[]   @relation("CommissionLedgerDeletedBy")
  commissionApprovalsRequested CommissionApproval[] @relation("CommissionApprovalRequestedBy")
  commissionApprovalsApproved  CommissionApproval[] @relation("CommissionApprovalApprovedBy")
  commissionPaymentsCreated    CommissionPayment[]  @relation("CommissionPaymentCreatedBy")
  commissionPaymentsApproved   CommissionPayment[]  @relation("CommissionPaymentApprovedBy")
  commissionPaymentsReleased   CommissionPayment[]  @relation("CommissionPaymentReleasedBy")
  commissionPaymentsDeleted    CommissionPayment[]  @relation("CommissionPaymentDeletedBy")
  commissionAdjustmentsCreated CommissionAdjustment[] @relation("CommissionAdjustmentCreatedBy")
  commissionAdjustmentsApproved CommissionAdjustment[] @relation("CommissionAdjustmentApprovedBy")
  commissionAdjustmentsDeleted CommissionAdjustment[] @relation("CommissionAdjustmentDeletedBy")
  commissionRecoveriesCreated  CommissionRecovery[] @relation("CommissionRecoveryCreatedBy")
  commissionRecoveriesApproved CommissionRecovery[] @relation("CommissionRecoveryApprovedBy")
  commissionRecoveriesDeleted  CommissionRecovery[] @relation("CommissionRecoveryDeletedBy")
  notificationTemplatesCreated NotificationTemplate[] @relation("NotificationTemplateCreatedBy")
  notificationTemplatesUpdated NotificationTemplate[] @relation("NotificationTemplateUpdatedBy")
  notificationTemplatesDeleted NotificationTemplate[] @relation("NotificationTemplateDeletedBy")
  notificationPreferences      NotificationPreference[]
  notifications                Notification[]
  notificationsDeleted         Notification[]         @relation("NotificationDeletedBy")
  communicationLogsReceived    CommunicationLog[]     @relation("CommunicationLogRecipient")
  emailLogsReceived            EmailLog[]             @relation("EmailLogRecipient")
  smsLogsReceived              SmsLog[]               @relation("SmsLogRecipient")
  whatsAppLogsReceived         WhatsAppLog[]          @relation("WhatsAppLogRecipient")
  pushNotifications            PushNotification[]
  notificationQueueItems       NotificationQueue[]    @relation("NotificationQueueRecipient")
  pushTopicSubscriptions       PushTopicSubscription[] @relation("PushTopicSubscriptions")
  emailTemplatesCreated        EmailTemplate[]         @relation("EmailTemplateCreatedBy")
  emailTemplatesUpdated        EmailTemplate[]         @relation("EmailTemplateUpdatedBy")
  emailTemplateVersionsCreated EmailTemplateVersion[]  @relation("EmailTemplateVersionCreatedBy")
  emailQueueItems              EmailQueue[]            @relation("EmailQueueRecipient")
  emailPreferences             EmailPreference[]       @relation("EmailPreferences")
  smsTemplatesCreated          SmsTemplate[]           @relation("SmsTemplateCreatedBy")
  smsTemplatesUpdated          SmsTemplate[]           @relation("SmsTemplateUpdatedBy")
  smsTemplateVersionsCreated   SmsTemplateVersion[]    @relation("SmsTemplateVersionCreatedBy")
  smsQueueItems                SmsQueue[]              @relation("SmsQueueRecipient")
  smsPreferences               SmsPreference[]         @relation("SmsPreferences")
  pushTemplatesCreated         PushTemplate[]          @relation("PushTemplateCreatedBy")
  pushTemplatesUpdated         PushTemplate[]          @relation("PushTemplateUpdatedBy")
  pushTemplateVersionsCreated  PushTemplateVersion[]   @relation("PushTemplateVersionCreatedBy")
  pushDevices                  PushDevice[]            @relation("PushDevices")
  pushQueueItems               PushQueue[]             @relation("PushQueueRecipient")
  pushPreferences              PushPreference[]        @relation("PushPreferences")
  ticketsCreated               Ticket[]               @relation("TicketCreatedBy")
  ticketsUpdated               Ticket[]               @relation("TicketUpdatedBy")
  ticketsDeleted               Ticket[]               @relation("TicketDeletedBy")
  ticketsAssigned              Ticket[]               @relation("TicketAssignedUser")
  ticketMessages               TicketMessage[]        @relation("TicketMessageAuthor")
  ticketAssignmentsMade        TicketAssignment[]     @relation("TicketAssignmentBy")
  ticketAssignmentsReceived    TicketAssignment[]     @relation("TicketAssignmentUser")
  ticketEscalations            TicketEscalation[]     @relation("TicketEscalatedBy")
  ticketResolutions            TicketResolution[]     @relation("TicketResolvedBy")
  ticketAttachments            TicketAttachment[]     @relation("TicketAttachmentUploadedBy")
  dashboardsCreated            Dashboard[]            @relation("DashboardCreatedBy")
  analyticsReportsCreated      AnalyticsReport[]      @relation("AnalyticsReportCreatedBy")
  reportExecutions             ReportExecution[]      @relation("ReportExecutionBy")
  analyticsSchedulesCreated    AnalyticsSchedule[]    @relation("AnalyticsScheduleCreatedBy")
  analyticsAudits              AnalyticsAudit[]       @relation("AnalyticsAuditUser")
  executiveTargetsAssigned     ExecutiveTarget[]      @relation("ExecutiveTargetAssignedBy")
  executiveAnalyticsAudits     ExecutiveAnalyticsAudit[] @relation("ExecutiveAnalyticsAuditUser")
  branchTargetsAssigned        BranchTarget[]            @relation("BranchTargetAssignedBy")
  branchAnalyticsAudits        BranchAnalyticsAudit[]    @relation("BranchAnalyticsAuditUser")
  regionalTargetsAssigned      RegionalTarget[]          @relation("RegionalTargetAssignedBy")
  regionalAnalyticsAudits      RegionalAnalyticsAudit[]  @relation("RegionalAnalyticsAuditUser")
  automationWorkflowsCreated   AutomationWorkflow[]      @relation("AutomationWorkflowCreatedBy")
  automationWorkflowsUpdated   AutomationWorkflow[]      @relation("AutomationWorkflowUpdatedBy")
