model User {
  id            String    @id @default(uuid()) @db.Char(36)
  email         String?   @unique @db.VarChar(255)
  phone         String?   @unique @db.VarChar(15)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  userType      String    @map("user_type") @db.VarChar(20)
  status        String    @default("ACTIVE") @db.VarChar(20)
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  userRoles      UserRole[]
  sessions       Session[]
  refreshTokens  RefreshToken[]
  otpVerifications OtpVerification[]
  devices        Device[]
  loginHistory   LoginHistory[]
  customer       Customer?
  customersCreated Customer[] @relation("CustomerCreatedBy")
  customersUpdated Customer[] @relation("CustomerUpdatedBy")
  customersDeleted Customer[] @relation("CustomerDeletedBy")
  kycAuditsPerformed KycAuditLog[] @relation("KycAuditPerformedBy")
  leadsCreated     Lead[] @relation("LeadCreatedBy")
  leadsUpdated     Lead[] @relation("LeadUpdatedBy")
  leadStatusChanges LeadStatusHistory[] @relation("LeadStatusChangedBy")
  leadActivities   LeadActivity[] @relation("LeadActivityPerformedBy")
  leadNotes        LeadNote[] @relation("LeadNoteAuthor")
  leadFollowUpsCreated LeadFollowUp[] @relation("LeadFollowUpCreatedBy")
  applicationsCreated  Application[] @relation("ApplicationCreatedBy")
  applicationsUpdated  Application[] @relation("ApplicationUpdatedBy")
  applicationStatusChanges ApplicationStatusHistory[] @relation("ApplicationStatusChangedBy")
  applicationTimelineEvents ApplicationTimeline[] @relation("ApplicationTimelinePerformedBy")
  eligibilityResultsChecked EligibilityResult[] @relation("EligibilityResultCheckedBy")
  sanctionsCreated     Sanction[] @relation("SanctionCreatedBy")
  disbursementsCreated Disbursement[] @relation("DisbursementCreatedBy")
  closuresCreated      Closure[] @relation("ClosureCreatedBy")
  documentsUploaded    Document[] @relation("DocumentUploadedBy")
  presignedUploadIntents PresignedUploadIntent[] @relation("PresignedUploadRequestedBy")
  documentsVerified    Document[] @relation("DocumentVerifiedBy")
  documentVersionsUploaded DocumentVersion[] @relation("DocumentVersionUploadedBy")
  documentRequests     DocumentRequest[] @relation("DocumentRequestRequestedBy")
  verificationResults  VerificationResult[] @relation("VerificationResultVerifiedBy")
