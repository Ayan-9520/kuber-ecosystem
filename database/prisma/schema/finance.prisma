// ── Finance Engine Domain ──

model FinanceCalculation {
  id              String                 @id @default(uuid()) @db.Char(36)
  calculationKind FinanceCalculationKind @map("calculation_kind")
  productSlug     FinanceProductSlug?    @map("product_slug")
  productId       String?                @map("product_id") @db.Char(36)
  variantId       String?                @map("variant_id") @db.Char(36)
  customerId      String?                @map("customer_id") @db.Char(36)
  leadId          String?                @map("lead_id") @db.Char(36)
  applicationId   String?                @map("application_id") @db.Char(36)
  cacheKey        String?                @unique @map("cache_key") @db.VarChar(64)
  inputPayload    Json                   @map("input_payload")
  outputPayload   Json                   @map("output_payload")
  engineVersion   String                 @default("1.0.0") @map("engine_version") @db.VarChar(20)
  computedById    String?                @map("computed_by") @db.Char(36)
  ipAddress       String?                @map("ip_address") @db.VarChar(45)
  requestId       String?                @map("request_id") @db.VarChar(64)
  createdAt       DateTime               @default(now()) @map("created_at")

  product     Product?     @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  lead        Lead?        @relation(fields: [leadId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])
  computedBy  User?        @relation("FinanceCalculationComputedBy", fields: [computedById], references: [id])

  @@index([calculationKind, createdAt])
  @@index([customerId])
  @@index([productSlug])
  @@index([applicationId])
  @@map("finance_calculations")
}
