// ── KuberOne Enterprise Analytics Dashboard Engine ──

enum MetricCategory {
  LEAD
  APPLICATION
  DISBURSEMENT
  REVENUE
  COMMISSION
  PARTNER
  EXECUTIVE
  SUPPORT
  AI
  NOTIFICATION
  DOCUMENT
  CUSTOMER
  REFERRAL
}

enum DashboardType {
  SYSTEM
  BUSINESS
  OPERATIONS
  SALES
  CREDIT
  MANAGEMENT
}

enum ChartType {
  LINE
  BAR
  AREA
  PIE
  TABLE
  SCORECARD
  TREND
}

enum AnalyticsExportFormat {
  CSV
  EXCEL
  PDF
}

enum AnalyticsReportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AnalyticsScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum AnalyticsTimePreset {
  TODAY
  YESTERDAY
  THIS_WEEK
  THIS_MONTH
  THIS_QUARTER
  THIS_YEAR
  CUSTOM
}

model MetricDefinition {
  id          String         @id @default(uuid()) @db.Char(36)
  code        String         @unique @db.VarChar(80)
  name        String         @db.VarChar(150)
  category    MetricCategory
  description String?        @db.Text
  unit        String?        @db.VarChar(30)
  formula     String?        @db.VarChar(255)
  isActive    Boolean        @default(true) @map("is_active")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  values MetricValue[]

  @@index([category, isActive])
  @@map("metric_definitions")
}

model MetricValue {
  id                 String   @id @default(uuid()) @db.Char(36)
  metricDefinitionId String   @map("metric_definition_id") @db.Char(36)
  snapshotDate       DateTime @map("snapshot_date") @db.Date
  branchId           String?  @map("branch_id") @db.Char(36)
  regionId           String?  @map("region_id") @db.Char(36)
  partnerId          String?  @map("partner_id") @db.Char(36)
  employeeId         String?  @map("employee_id") @db.Char(36)
  value              Decimal  @db.Decimal(18, 4)
  dimensions         Json?
  createdAt          DateTime @default(now()) @map("created_at")

  metricDefinition MetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)

  @@unique([metricDefinitionId, snapshotDate, branchId, regionId, partnerId, employeeId], map: "metric_values_def_date_scope_key")
  @@index([snapshotDate, branchId, regionId])
  @@map("metric_values")
}

model Dashboard {
  id          String        @id @default(uuid()) @db.Char(36)
  code        String        @unique @db.VarChar(80)
  name        String        @db.VarChar(150)
  dashboardType DashboardType @map("dashboard_type")
  description String?       @db.Text
  isSystem    Boolean       @default(false) @map("is_system")
  isActive    Boolean       @default(true) @map("is_active")
  layout      Json?
  createdById String?       @map("created_by_id") @db.Char(36)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  createdBy User?             @relation("DashboardCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  widgets   DashboardWidget[]
  filters   DashboardFilter[]

  @@index([dashboardType, isActive])
  @@map("dashboards")
}

model DashboardWidget {
  id          String    @id @default(uuid()) @db.Char(36)
  dashboardId String    @map("dashboard_id") @db.Char(36)
  title       String    @db.VarChar(150)
  chartType   ChartType @map("chart_type")
  metricCode  String?   @map("metric_code") @db.VarChar(80)
  config      Json?
  position    Int       @default(0)
  width       Int       @default(6)
  height      Int       @default(4)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId, position])
  @@map("dashboard_widgets")
}

model DashboardFilter {
  id          String              @id @default(uuid()) @db.Char(36)
  dashboardId String              @map("dashboard_id") @db.Char(36)
  filterKey   String              @map("filter_key") @db.VarChar(80)
  filterValue String?             @map("filter_value") @db.VarChar(255)
  timePreset  AnalyticsTimePreset? @map("time_preset")
  fromDate    DateTime?           @map("from_date")
  toDate      DateTime?           @map("to_date")
  branchId    String?             @map("branch_id") @db.Char(36)
  regionId    String?             @map("region_id") @db.Char(36)
  partnerId   String?             @map("partner_id") @db.Char(36)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("dashboard_filters")
}

model AnalyticsSnapshot {
  id           String        @id @default(uuid()) @db.Char(36)
  snapshotDate DateTime      @map("snapshot_date") @db.Date
  dashboardType DashboardType? @map("dashboard_type")
  branchId     String?       @map("branch_id") @db.Char(36)
  regionId     String?       @map("region_id") @db.Char(36)
  partnerId    String?       @map("partner_id") @db.Char(36)
  payload      Json
  createdAt    DateTime      @default(now()) @map("created_at")

  @@unique([snapshotDate, dashboardType, branchId, regionId, partnerId], map: "analytics_snapshots_date_scope_key")
  @@index([snapshotDate])
  @@map("analytics_snapshots")
}

model AnalyticsReport {
  id          String                @id @default(uuid()) @db.Char(36)
  code        String                @unique @db.VarChar(80)
  name        String                @db.VarChar(150)
  reportType  String                @map("report_type") @db.VarChar(50)
  description String?               @db.Text
  config      Json?
  isActive    Boolean               @default(true) @map("is_active")
  createdById String?               @map("created_by_id") @db.Char(36)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  createdBy  User?             @relation("AnalyticsReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  executions ReportExecution[]
  schedules  AnalyticsSchedule[]

  @@map("analytics_reports")
}

model ReportExecution {
  id           String                @id @default(uuid()) @db.Char(36)
  reportId     String                @map("report_id") @db.Char(36)
  status       AnalyticsReportStatus @default(PENDING)
  format       AnalyticsExportFormat @default(CSV)
  parameters   Json?
  resultUrl    String?               @map("result_url") @db.VarChar(500)
  rowCount     Int?                  @map("row_count")
  errorMessage String?               @map("error_message") @db.Text
  startedAt    DateTime?             @map("started_at")
  completedAt  DateTime?             @map("completed_at")
  executedById String?               @map("executed_by_id") @db.Char(36)
  createdAt    DateTime              @default(now()) @map("created_at")

  report     AnalyticsReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  executedBy User?           @relation("ReportExecutionBy", fields: [executedById], references: [id], onDelete: SetNull)

  @@index([reportId, status, createdAt])
  @@map("report_executions")
}

model AnalyticsSchedule {
  id             String                   @id @default(uuid()) @db.Char(36)
  reportId       String                   @map("report_id") @db.Char(36)
  name           String                   @db.VarChar(150)
  frequency      AnalyticsScheduleFrequency
  cronExpression String?                  @map("cron_expression") @db.VarChar(80)
  timezone       String                   @default("Asia/Kolkata") @db.VarChar(50)
  recipients     Json?
  format         AnalyticsExportFormat    @default(CSV)
  isActive       Boolean                  @default(true) @map("is_active")
  lastRunAt      DateTime?                @map("last_run_at")
  nextRunAt      DateTime?                @map("next_run_at")
  createdById    String?                  @map("created_by_id") @db.Char(36)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  report    AnalyticsReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("AnalyticsScheduleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive, nextRunAt])
  @@map("analytics_schedules")
}

model AnalyticsAudit {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @map("user_id") @db.Char(36)
  action     String   @db.VarChar(80)
  resource   String   @db.VarChar(80)
  resourceId String?  @map("resource_id") @db.Char(36)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation("AnalyticsAuditUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("analytics_audits")
}
