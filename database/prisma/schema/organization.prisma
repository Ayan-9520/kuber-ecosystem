model Region {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches            Branch[]
  lmsAssignmentRules  LmsAssignmentRule[]
  leads               Lead[]
  applications        Application[]
  tickets             Ticket[]
  regionalMetrics     RegionalMetric[]
  regionalTargets     RegionalTarget[]
  regionalPerformances RegionalPerformance[]
  regionalForecasts   RegionalForecast[]
  regionalRankings    RegionalRanking[]
  regionalSnapshots   RegionalAnalyticsSnapshot[]
  automationWorkflows AutomationWorkflow[]

  @@map("regions")
}

model Branch {
  id        String   @id @default(uuid()) @db.Char(36)
  regionId  String   @map("region_id") @db.Char(36)
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(150)
  address   String?  @db.Text
  city      String?  @db.VarChar(100)
  state     String?  @db.VarChar(100)
  pincode   String?  @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  region             Region              @relation(fields: [regionId], references: [id])
  employees          Employee[]
  customers          Customer[]
  lmsAssignmentRules LmsAssignmentRule[]
  leads              Lead[]
  leadAssignments    LeadAssignment[]
  applications       Application[]
  referrals          Referral[]
  commissionLedger   CommissionLedger[]
  tickets            Ticket[]
  branchMetrics      BranchMetric[]
  branchTargets      BranchTarget[]
  branchPerformances BranchPerformance[]
  branchForecasts    BranchForecast[]
  branchRankings     BranchRanking[]
  branchSnapshots    BranchAnalyticsSnapshot[]
  regionalRankings   RegionalRanking[]
  automationWorkflows AutomationWorkflow[]
  campaigns           Campaign[]

  @@index([regionId, isActive])
  @@map("branches")
}

model Employee {
  id           String    @id @default(uuid()) @db.Char(36)
  userId       String    @unique @map("user_id") @db.Char(36)
  branchId     String    @map("branch_id") @db.Char(36)
  employeeCode String    @unique @map("employee_code") @db.VarChar(30)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  designation  String?   @db.VarChar(100)
  department   String?   @db.VarChar(50)
  reportsToId  String?   @map("reports_to_id") @db.Char(36)
  isActive     Boolean   @default(true) @map("is_active")
  joinedAt     DateTime? @map("joined_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdById  String?   @map("created_by") @db.Char(36)
  updatedById  String?   @map("updated_by") @db.Char(36)
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by") @db.Char(36)

  branch Branch @relation(fields: [branchId], references: [id])
  managedCustomers Customer[] @relation("CustomerRmEmployee")

  workflowDefinitionsCreated  WorkflowDefinition[] @relation("WorkflowDefinitionCreatedBy")
  workflowDefinitionsUpdated  WorkflowDefinition[] @relation("WorkflowDefinitionUpdatedBy")
  workflowDefinitionsApproved WorkflowDefinition[] @relation("WorkflowDefinitionApprovedBy")
  lmsAssignmentRulesCreated   LmsAssignmentRule[]  @relation("LmsAssignmentRuleCreatedBy")
  lmsAssignmentRulesUpdated   LmsAssignmentRule[]  @relation("LmsAssignmentRuleUpdatedBy")
  lmsScoringConfigsCreated    LmsScoringConfig[]   @relation("LmsScoringConfigCreatedBy")
  lmsScoringConfigsUpdated    LmsScoringConfig[]   @relation("LmsScoringConfigUpdatedBy")
  lmsEscalationsAssigned      LmsEscalationRule[]  @relation("LmsEscalationEmployee")
  notificationRulesCreated      NotificationRuleConfig[] @relation("NotificationRuleConfigCreatedBy")
  notificationRulesUpdated      NotificationRuleConfig[] @relation("NotificationRuleConfigUpdatedBy")
  approvalRuleConfigsCreated  ApprovalRuleConfig[] @relation("ApprovalRuleConfigCreatedBy")
  approvalRuleConfigsUpdated    ApprovalRuleConfig[] @relation("ApprovalRuleConfigUpdatedBy")

  assignedLeads               Lead[]               @relation("LeadAssignedTo")
  leadAssignmentsReceived     LeadAssignment[]     @relation("LeadAssignmentAssignee")
  leadAssignmentsMade         LeadAssignment[]     @relation("LeadAssignmentAssigner")
  leadFollowUps               LeadFollowUp[]       @relation("LeadFollowUpAssignee")
  applicationsSales           Application[]        @relation("ApplicationAssignedSales")
  applicationsCredit          Application[]        @relation("ApplicationAssignedCredit")
  applicationsOps             Application[]        @relation("ApplicationAssignedOps")
  bankLoginsSubmitted         BankLogin[]          @relation("BankLoginSubmittedBy")
  creditReviews               CreditReview[]       @relation("CreditReviewReviewer")
  closuresRm                  Closure[]            @relation("ClosureRmAssigned")
  documents                   Document[]
  referralsAsReferrer         Referral[]           @relation("ReferralReferrerEmployee")
  ticketsAssigned             Ticket[]             @relation("TicketAssignedEmployee")
  ticketAssignments           TicketAssignment[]   @relation("TicketAssignmentEmployee")
  executiveMetrics            ExecutiveMetric[]
  executiveTargets            ExecutiveTarget[]
  executivePerformances       ExecutivePerformance[]
  executiveLeaderboards       ExecutiveLeaderboard[]
  executiveForecasts          ExecutiveForecast[]
  executiveAnalyticsSnapshots ExecutiveAnalyticsSnapshot[]

  @@index([branchId, isActive])
  @@index([reportsToId])
  @@map("employees")
}
