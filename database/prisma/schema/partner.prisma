model PartnerType {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  partners Partner[]

  @@map("partner_types")
}

model Partner {
  id             String    @id @default(uuid()) @db.Char(36)
  userId         String    @unique @map("user_id") @db.Char(36)
  partnerTypeId  String    @map("partner_type_id") @db.Char(36)
  partnerCode    String    @unique @map("partner_code") @db.VarChar(30)
  businessName   String?   @map("business_name") @db.VarChar(200)
  contactName    String    @map("contact_name") @db.VarChar(150)
  phone          String    @db.VarChar(15)
  email          String?   @db.VarChar(255)
  kycStatus      String    @default("NOT_STARTED") @map("kyc_status") @db.VarChar(30)
  status         String    @default("PENDING") @db.VarChar(20)
  commissionTier String?   @map("commission_tier") @db.VarChar(20)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  partnerType PartnerType @relation(fields: [partnerTypeId], references: [id])
  leads       Lead[]
  applications Application[]
  documents    Document[]
  referralsAsReferrer Referral[] @relation("ReferralReferrerPartner")
  referralsAsChannel  Referral[] @relation("ReferralChannelPartner")
  commissionLedger    CommissionLedger[]
  commissionPayments  CommissionPayment[]
  commissionAdjustments CommissionAdjustment[]
  commissionRecoveries  CommissionRecovery[]
  tickets               Ticket[]

  @@map("partners")
  @@index([partnerTypeId, status])
}
