{
  "name": "@kuberone/database",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne Prisma database package",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "prisma generate --schema=./prisma/schema",
    "migrate:dev": "prisma migrate dev --schema=./prisma/schema",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema",
    "migrate:reset": "prisma migrate reset --schema=./prisma/schema --force",
    "seed": "tsx prisma/seeds/index.ts",
    "studio": "prisma studio --schema=./prisma/schema",
    "lint": "eslint src prisma/seeds --max-warnings 0",
    "lint:fix": "eslint src prisma/seeds --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.seeds.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^2.4.3",
    "mysql2": "^3.22.4",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seeds/index.ts"
  }
}
