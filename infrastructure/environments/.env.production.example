# KuberOne Production — DO NOT COMMIT WITH REAL SECRETS
# Use AWS Secrets Manager: kuberone/production/*

NODE_ENV=production
APP_ENV=production

API_PORT=4000
API_BASE_URL=https://api.kuberone.com
CORS_ORIGINS=https://admin.kuberone.com,https://customer.kuberone.com,https://partner.kuberone.com

# MySQL 8 (RDS Multi-AZ)
DATABASE_URL=mysql://kuberone:CHANGE_ME@mysql.internal:3306/kuberone?connection_limit=20

# Redis (ElastiCache cluster)
REDIS_URL=rediss://:CHANGE_ME@redis-cluster.internal:6379

# AWS S3 Production
AWS_REGION=ap-south-1
AWS_S3_BUCKET=kuberone-production
AWS_S3_BACKUP_BUCKET=kuberone-production-backups

# JWT
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS

# AI
OPENAI_API_KEY=

# Communications
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMS_API_KEY=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
FCM_SERVER_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel.internal:4317
LOG_LEVEL=info
ERROR_GATE_MAX_CRITICAL=5

# Webhooks
PRODUCTION_WEBHOOK_SECRET=CHANGE_ME
DEVOPS_WEBHOOK_SECRET=CHANGE_ME

# Admin
VITE_API_BASE_URL=https://api.kuberone.com/api/v1
