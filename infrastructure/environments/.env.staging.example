# KuberOne Staging Environment
NODE_ENV=production
APP_ENV=staging

API_PORT=4000
API_BASE_URL=https://staging-api.kuberone.com
CORS_ORIGINS=https://staging-admin.kuberone.com,https://staging-customer.kuberone.com,https://staging-partner.kuberone.com

# Dedicated staging MySQL (masked data)
STAGING_DATABASE_URL=mysql://kuberone:CHANGE_ME@staging-mysql:3306/kuberone_staging
DATABASE_URL=mysql://kuberone:CHANGE_ME@staging-mysql:3306/kuberone_staging

# Dedicated staging Redis
STAGING_REDIS_URL=rediss://:CHANGE_ME@staging-redis:6379
REDIS_URL=rediss://:CHANGE_ME@staging-redis:6379

# Dedicated staging S3
AWS_S3_BUCKET=kuberone-staging
AWS_S3_BACKUP_BUCKET=kuberone-staging-backups
STAGING_S3_BUCKET=kuberone-staging

# Secrets (use AWS Secrets Manager in live staging)
JWT_ACCESS_SECRET=CHANGE_ME_STAGING
JWT_REFRESH_SECRET=CHANGE_ME_STAGING
OPENAI_API_KEY=
SMTP_HOST=
SMS_API_KEY=
WHATSAPP_API_KEY=
FCM_SERVER_KEY=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel:4317
LOG_LEVEL=debug

# Staging webhook
STAGING_WEBHOOK_SECRET=CHANGE_ME

# Admin
VITE_API_BASE_URL=https://staging-api.kuberone.com/api/v1

# UAT
SEED_MASK_PII=true
