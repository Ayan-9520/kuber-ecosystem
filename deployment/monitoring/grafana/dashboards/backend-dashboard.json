{
  "uid": "kuberone-backend",
  "title": "KuberOne Backend Dashboard",
  "tags": ["kuberone", "backend"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    { "type": "timeseries", "title": "API Request Rate", "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }, "targets": [{ "expr": "rate(kuberone_http_requests_total[5m])", "legendFormat": "{{method}} {{route}}" }] },
    { "type": "timeseries", "title": "API Latency P95", "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }, "targets": [{ "expr": "histogram_quantile(0.95, rate(kuberone_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" }] },
    { "type": "timeseries", "title": "Error Rate", "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }, "targets": [{ "expr": "rate(kuberone_http_errors_total[5m])", "legendFormat": "errors" }] },
    { "type": "stat", "title": "Concurrent Users", "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }, "targets": [{ "expr": "kuberone_concurrent_users" }] }
  ]
}
