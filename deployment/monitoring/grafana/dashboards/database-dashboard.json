{
  "uid": "kuberone-database",
  "title": "KuberOne Database Dashboard",
  "tags": ["kuberone", "database"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    { "type": "stat", "title": "MySQL Up", "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }, "targets": [{ "expr": "mysql_up" }] },
    { "type": "stat", "title": "Connections", "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }, "targets": [{ "expr": "mysql_global_status_threads_connected" }] },
    { "type": "timeseries", "title": "Slow Queries", "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }, "targets": [{ "expr": "rate(mysql_global_status_slow_queries[5m])" }] },
    { "type": "timeseries", "title": "Database Size", "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }, "targets": [{ "expr": "mysql_info_schema_table_rows" }] }
  ]
}
