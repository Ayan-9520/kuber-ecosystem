{
  "uid": "kuberone-errors-backend",
  "title": "KuberOne Backend Error Dashboard",
  "tags": ["kuberone", "errors", "backend"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    { "type": "timeseries", "title": "5xx Errors", "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }, "targets": [{ "expr": "sum(rate(kuberone_http_requests_total{status=~\"5..\"}[5m]))", "datasource": "Prometheus" }] },
    { "type": "timeseries", "title": "API Error Rate", "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }, "targets": [{ "expr": "rate(kuberone_http_errors_total[5m])", "datasource": "Prometheus" }] },
    { "type": "logs", "title": "Backend Error Logs", "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 }, "targets": [{ "expr": "{service=\"kuberone-api\"} | json | level=\"error\"", "datasource": "Loki" }] }
  ]
}
