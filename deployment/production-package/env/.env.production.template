# =============================================================================
# KuberOne Production Environment Template
# Company: Kuber Finserve | Region: ap-south-1 (Mumbai)
# DO NOT COMMIT WITH REAL SECRETS — use AWS Secrets Manager: kuberone/production/*
# =============================================================================

# --- Core ---
NODE_ENV=production
APP_ENV=production
API_PORT=4000
API_BASE_URL=https://api.kuberone.com
API_VERSION=v1
CORS_ORIGINS=https://admin.kuberone.com,https://customer.kuberone.com,https://partner.kuberone.com

# --- Staged rollout (default) — deploy with MySQL + OpenAI; add providers before public launch ---
DEPLOYMENT_ROLLOUT_PHASE=staged
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
NOTIFICATION_WHATSAPP_ENABLED=true
NOTIFICATION_PUSH_ENABLED=true

# --- MySQL 8 (RDS Multi-AZ) ---
DATABASE_URL=mysql://kuberone_app:CHANGE_ME@kuberone-prod-mysql.xxxxx.ap-south-1.rds.amazonaws.com:3306/kuberone?connection_limit=20&pool_timeout=20
DATABASE_CONNECTION_LIMIT=20

# --- Redis (ElastiCache cluster mode, TLS) — optional in staged rollout ---
REDIS_URL=rediss://:CHANGE_ME@kuberone-prod-redis.xxxxx.cache.amazonaws.com:6379

# --- JWT & Encryption ---
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
DATA_ENCRYPTION_KEY=CHANGE_ME_FIELD_ENCRYPTION_32_CHARS_MIN

# --- AWS ---
AWS_REGION=ap-south-1
# Prefer IAM instance role on EC2; omit keys when using role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kuberone-production
AWS_S3_BACKUP_BUCKET=kuberone-production-backups

# --- OpenAI ---
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.35
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- RAG (production: local MySQL-backed embeddings) ---
EMBEDDING_PROVIDER=openai
VECTOR_DB_PROVIDER=local
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_MIN_SCORE=0.3

# --- Email (choose one provider) ---
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.CHANGE_ME
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.CHANGE_ME
# EMAIL_PROVIDER=aws_ses
# AWS_SES_REGION=ap-south-1
# AWS_SES_ACCESS_KEY=
# AWS_SES_SECRET_KEY=
EMAIL_FROM=noreply@kuberfinserve.com
EMAIL_FROM_NAME=Kuber Finserve
EMAIL_WORKER_ENABLED=true

# --- SMS ---
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=CHANGE_ME
MSG91_TEMPLATE_ID=CHANGE_ME
MSG91_SENDER_ID=KUBERF
SMS_WORKER_ENABLED=true

# --- WhatsApp Business (Meta Cloud API) ---
WHATSAPP_BUSINESS_API_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME
WHATSAPP_API_VERSION=v21.0

# --- Push (Firebase FCM) ---
PUSH_PROVIDER=fcm
FCM_PROJECT_ID=kuberone-production
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@kuberone-production.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
# Legacy server key (optional if using service account)
FCM_SERVER_KEY=
FIREBASE_PROJECT_ID=kuberone-production
PUSH_WORKER_ENABLED=true

# --- Workers (API nodes: false; worker nodes: true) ---
API_WORKERS_ENABLED=false
AUTOMATION_WORKER_ENABLED=true
CONTENT_WORKER_ENABLED=true
BACKUP_WORKER_ENABLED=true
NOTIFICATION_WORKER_ENABLED=true
EMAIL_WORKER_INTERVAL_MS=10000
SMS_WORKER_INTERVAL_MS=10000
PUSH_WORKER_INTERVAL_MS=10000

# --- Auth / Rate limits ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

# --- Observability ---
LOG_LEVEL=info
LOG_SAMPLE_RATE=0.1
TRACE_SAMPLE_RATE=0.1
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel.internal.kuberone.com:4317

# --- Backup ---
BACKUP_WORKER_ENABLED=true
BACKUP_WORKER_INTERVAL_MS=3600000

# --- Deployment gates ---
ERROR_GATE_MAX_CRITICAL=5

# --- Webhooks (CI/CD, mobile, DR) ---
DEVOPS_WEBHOOK_SECRET=CHANGE_ME_MIN_32
PRODUCTION_WEBHOOK_SECRET=CHANGE_ME_MIN_32
STAGING_WEBHOOK_SECRET=CHANGE_ME_MIN_32
MOBILE_WEBHOOK_SECRET=CHANGE_ME_MIN_32
PLAY_STORE_WEBHOOK_SECRET=CHANGE_ME_MIN_32
APP_STORE_WEBHOOK_SECRET=CHANGE_ME_MIN_32
BACKEND_DEPLOYMENT_WEBHOOK_SECRET=CHANGE_ME_MIN_32
DR_WEBHOOK_SECRET=CHANGE_ME_MIN_32

# --- Admin CRM build-time (set in CI / EAS secrets) ---
VITE_API_BASE_URL=https://api.kuberone.com/api/v1
VITE_APP_ENV=production
VITE_USE_MOCK=false
