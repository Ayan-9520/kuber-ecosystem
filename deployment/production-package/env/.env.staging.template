# =============================================================================
# KuberOne Staging Environment Template
# Mirrors production topology at reduced scale — masked PII for UAT
# Secrets: AWS Secrets Manager kuberone/staging/* or SSM Parameter Store
# =============================================================================

NODE_ENV=production
APP_ENV=staging

API_PORT=4000
API_BASE_URL=https://staging-api.kuberone.com
API_VERSION=v1
CORS_ORIGINS=https://staging-admin.kuberone.com,https://staging-customer.kuberone.com,https://staging-partner.kuberone.com

# --- MySQL 8 (dedicated staging RDS or Docker mysql:8.0) ---
DATABASE_URL=mysql://kuberone:CHANGE_ME@staging-mysql.internal:3306/kuberone_staging?connection_limit=10
STAGING_DATABASE_URL=mysql://kuberone:CHANGE_ME@staging-mysql.internal:3306/kuberone_staging
DATABASE_CONNECTION_LIMIT=10

# --- Redis ---
REDIS_URL=rediss://:CHANGE_ME@staging-redis.internal:6379
STAGING_REDIS_URL=rediss://:CHANGE_ME@staging-redis.internal:6379

JWT_ACCESS_SECRET=CHANGE_ME_STAGING_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_STAGING_MIN_32_CHARS
DATA_ENCRYPTION_KEY=CHANGE_ME_STAGING_ENCRYPTION_KEY

AWS_REGION=ap-south-1
AWS_S3_BUCKET=kuberone-staging
AWS_S3_BACKUP_BUCKET=kuberone-staging-backups
STAGING_S3_BUCKET=kuberone-staging

# Providers — use sandbox / test credentials
OPENAI_API_KEY=sk-CHANGE_ME
VECTOR_DB_PROVIDER=local
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
WHATSAPP_BUSINESS_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
PUSH_PROVIDER=fcm
FCM_PROJECT_ID=kuberone-staging
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

API_WORKERS_ENABLED=true
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel:4317
STAGING_WEBHOOK_SECRET=CHANGE_ME
SEED_MASK_PII=true
ERROR_GATE_MAX_CRITICAL=10

VITE_API_BASE_URL=https://staging-api.kuberone.com/api/v1
VITE_APP_ENV=staging
VITE_USE_MOCK=false
