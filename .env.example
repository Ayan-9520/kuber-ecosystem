# KuberOne Monorepo — Root Environment Template
# Copy to .env.local for local development overrides

NODE_ENV=development
APP_ENV=development

# Database (used by database package)
DATABASE_URL="mysql://root@127.0.0.1:3306/kuberone_dev"

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000
API_VERSION=v1

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kuberone-dev-documents

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:8082,http://localhost:8083

# Admin Panel
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Mobile Apps
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# --- Production / hosting (replace before deploy) ---
# APP_ENV=production
# DATABASE_URL=mysql://user:pass@host:3306/kuberone_prod
# CORS_ORIGINS=https://admin.yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
# EXPO_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_S3_BUCKET — required for document storage in prod
# REDIS_URL=redis://... — recommended for production rate limits & cache
# Run: pnpm db:migrate:deploy && pnpm db:seed (lead sources, products, lenders, employees)
