{
  "name": "@kuberone/shared-validation",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne shared Zod validation schemas",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/tsc.mjs -p tsconfig.json",
    "dev": "node ../../scripts/tsc.mjs -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "node ../../scripts/tsc.mjs -p tsconfig.json --noEmit",
    "test": "node ../../scripts/run-bin.mjs vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
