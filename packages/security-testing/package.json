{
  "name": "@kuberone/security-testing",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne enterprise security testing framework — OWASP, RBAC, payloads, scoring",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/tsc.mjs -p tsconfig.json",
    "typecheck": "node ../../scripts/tsc.mjs -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@kuberone/shared-types": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
