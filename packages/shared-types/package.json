{
  "name": "@kuberone/shared-types",
  "version": "1.0.0",
  "private": true,
  "description": "KuberOne shared TypeScript types, DTOs, and enums",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/tsc.mjs -p tsconfig.json",
    "dev": "node ../../scripts/tsc.mjs -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "node ../../scripts/tsc.mjs -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
