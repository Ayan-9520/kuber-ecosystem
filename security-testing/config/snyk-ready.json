{
  "$schema": "https://json.schemastore.org/snyk",
  "version": "1.0.0",
  "project": "kuberone",
  "organization": "kuber-finserv",
  "severityThreshold": "high",
  "failOn": ["critical", "high"],
  "monitor": true,
  "packageManager": "pnpm",
